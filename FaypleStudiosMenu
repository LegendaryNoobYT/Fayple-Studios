if game.PlaceId == 109983668079237 then
	local ReplicatedStorage = game:GetService("ReplicatedStorage")

	local Animals = require(ReplicatedStorage.Datas.Animals)
	local Mutations = require(ReplicatedStorage.Datas.Mutations)

	local BrainrotCard = require(ReplicatedStorage.Shared.BrainrotCard)

	local Sab = Window:CreateTab("Sab", "shield-check")
	local SabFirstLabel = Sab:CreateLabel("EVERYTHING HERE YOU SEE IS LOCAL AND OTHER PLAYERS WILL NOT SEE THIS", "triangle-alert", Color3.new(1, 1, 1), false) -- Title, Icon, Color, IgnoreTheme
	local CurrentBrainrot = ""
	local CurrentMutation = ""
	local SpawnOnlyOnce = true
	local BrainrotInput = Sab:CreateInput({
		Name = "Brainrot Name",
		CurrentValue = "",
		PlaceholderText = "Ex: Strawberry Elephant",
		RemoveTextAfterFocusLost = false,
		Flag = "Input1",
		Callback = function(Text)
			CurrentBrainrot = Text
			-- The function that takes place when the input is changed
			-- The variable (Text) is a string for the value in the text box
		end,
	})
	local MutationInput = Sab:CreateInput({
		Name = "Mutation Name",
		CurrentValue = "",
		PlaceholderText = "Ex: Cyber",
		RemoveTextAfterFocusLost = false,
		Flag = "Input2",
		Callback = function(Text)
			CurrentMutation = Text
			-- The function that takes place when the input is changed
			-- The variable (Text) is a string for the value in the text box
		end,
	})
	local Toggle = Sab:CreateToggle({
		Name = "Spawn Only Once",
		CurrentValue = true,
		Flag = "Toggle1", -- A flag is the identifier for the configuration file; make sure every element has a different flag if you're using configuration saving to ensure no overlaps
		Callback = function(Value)
			SpawnOnlyOnce = Value
			-- The function that takes place when the toggle is pressed
			-- The variable (Value) is a boolean on whether the toggle is true or false
		end,
	})
	local Spawn = Sab:CreateButton({
		Name = "Spawn A Brainrot",
		Callback = function()
			if not Animals[CurrentBrainrot] then
				Rayfield:Notify({
					Title = "Spawner",
					Content = 'Failed, brainrot named "'.. CurrentBrainrot ..'" doesnt exist.',
					Duration = 6.5,
					Image = "x",
				})
				return
			end

			if not Mutations[CurrentMutation] and CurrentMutation ~= nil and CurrentMutation ~= "" then
				Rayfield:Notify({
					Title = "Spawner",
					Content = 'Failed, mutation named "'.. CurrentMutation .. '" doesnt exist.',
					Duration = 6.5,
					Image = "x",
				})
				return
			end

			if _G.BrainrotSpawnConnection then
				_G.BrainrotSpawnConnection:Disconnect()
			end

			_G.BrainrotSpawnConnection = workspace.ChildAdded:Connect(function(c)

				c:SetAttribute("Index", CurrentBrainrot)
				if CurrentMutation and CurrentMutation ~= "" then c:SetAttribute("Mutation", CurrentMutation) end

				if SpawnOnlyOnce == true then
					_G.BrainrotSpawnConnection:Disconnect()
				end
			end)
			Rayfield:Notify({
				Title = "Spawn Brainrot",
				Content = "Successfuly Spawned.",
				Duration = 6.5,
				Image = "dollar-sign",
			})
		end,
	})
	local Slot = 1
	local OneOfOneInput = Sab:CreateInput({
		Name = "Fake 1 Of 1 Slot (Slot in Trade)",
		CurrentValue = "",
		PlaceholderText = "Ex: 1",
		RemoveTextAfterFocusLost = false,
		Flag = "Input2",
		Callback = function(Text)
			Slot = tonumber(Text) or 1
			if Slot > 99 then Slot = 99 end
		end,
	})
	local TradeLive = game.Players.LocalPlayer.PlayerGui:WaitForChild("TradeLiveTrade").TradeLiveTrade
	local Fake1Of1 = Sab:CreateButton({
		Name = "[TRADE] Fake One of One",
		Callback = function()
			for _, Child in TradeLive.Your.ScrollingFrame:GetChildren() do
				if Child.Name == "Selection_Brainrot_" .. tostring(Slot) then
					BrainrotCard.ApplyOneOfOne(Child, true)
					break
				end
			end
		end,
	})
	local TradingWithUserID
	local TradingWithName = "SpyderSammy"
	local Players = game:GetService("Players")
	local FakeUserInput = Sab:CreateInput({
		Name = "Trade With Fake Username",
		CurrentValue = "",
		PlaceholderText = "Ex: SpyderSammy",
		RemoveTextAfterFocusLost = false,
		Flag = "Input3",
		Callback = function(Text)
			TradingWithName = Text
		end,
	})
	local CurrentConnection
	local CurrentConnection1
	local CurrentConnection2
	local FakeUserTrade = Sab:CreateButton({
		Name = "Change User Youre Trading With",
		Callback = function()
			repeat
				local s, e = pcall(function()
					TradingWithUserID = Players:GetUserIdFromNameAsync(TradingWithName)
				end)
				task.wait(.01)
			until TradingWithUserID
			local Image = Players:GetUserThumbnailAsync(TradingWithUserID, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
			if CurrentConnection then
				CurrentConnection:Disconnect()
			end
			if CurrentConnection1 then
				CurrentConnection1:Disconnect()
			end
			if CurrentConnection2 then
				CurrentConnection1:Disconnect()
			end
			TradeLive.Other.Username.Text = TradingWithName .. "'s Offer"
			TradeLive.Other.PlayerImage.Headshot.Image = Image
			local IMAGE_DELAY = 0
			for _, Child in TradeLive.Chat.NormalChat.ScrollingFrame:GetChildren() do
				if not Child:IsA("Frame") then continue end
				if Child.Size.Y.Scale == 0.20000000298023224 then
					task.wait(IMAGE_DELAY)
					Child.PlayerImage.Headshot.Image = Image
				end
			end
			for _, Child in TradeLive.Chat.RestrictedChat.ScrollingFrame:GetChildren() do
				if not Child:IsA("Frame") then continue end
				if Child.Size.Y.Scale == 0.20000000298023224 then
					task.wait(IMAGE_DELAY)
					Child.PlayerImage.Headshot.Image = Image
				end
			end
			CurrentConnection = TradeLive.Chat.NormalChat.ScrollingFrame.ChildAdded:Connect(function(Child)
				if Child.Size.Y.Scale == 0.20000000298023224 then
					task.wait(IMAGE_DELAY)
					Child.PlayerImage.Headshot.Image = Image
				end
			end)
			CurrentConnection2 = TradeLive.Chat.RestrictedChat.ScrollingFrame.ChildAdded:Connect(function(Child)
				if Child.Size.Y.Scale == 0.20000000298023224 then
					task.wait(IMAGE_DELAY)
					Child.PlayerImage.Headshot.Image = Image
				end
			end)
			CurrentConnection1 = Players.LocalPlayer.PlayerGui.Notification.Notification.ChildAdded:Connect(function(child)
				if child:IsA("TextLabel") then
					if string.find(child.Text:lower(), " completed") then
						child.Text = "<font color=\"#92FF67\">Trade with @" .. TradingWithName .. " completed! 🎉</font>"
						CurrentConnection1:Disconnect()
					elseif string.find(child.Text:lower(), " canceled") then
						if child.Text == "<font color=\"#FA0103\">@" .. Players.LocalPlayer.Name .. " canceled</font>" then CurrentConnection1:Disconnect() return end
						child.Text = "<font color=\"#FA0103\">@" .. TradingWithName .. " canceled</font>"
						CurrentConnection1:Disconnect()
					end
				end
			end)
		end,
	})
	local SpawnPlayableModelName
	local SpawnPlayableModelMutation
	local SpawnPlayableModelNameInput = Sab:CreateInput({
		Name = "Playable Brainrot Name",
		CurrentValue = "",
		PlaceholderText = "Ex: Strawberry Elephant",
		RemoveTextAfterFocusLost = false,
		Flag = "Input4",
		Callback = function(Text)
			SpawnPlayableModelName = Text
		end,
	})
	local SpawnPlayableModelMutationInput = Sab:CreateInput({
		Name = "Playable Brainrot Mutation",
		CurrentValue = "",
		PlaceholderText = "Ex: Cyber",
		RemoveTextAfterFocusLost = false,
		Flag = "Input5",
		Callback = function(Text)
			SpawnPlayableModelMutation = Text
		end,
	})
	local PlayableBrainrotButton = Sab:CreateButton({
		Name = "Spawn Playable Brainrot",
		Callback = function()
			if not Animals[SpawnPlayableModelName] then
				Rayfield:Notify({
					Title = "Playable Spawner",
					Content = 'Failed, brainrot named "'.. SpawnPlayableModelName ..'" doesnt exist.',
					Duration = 6.5,
					Image = "x",
				})
				return
			end

			if not Mutations[SpawnPlayableModelMutation] and SpawnPlayableModelMutation ~= nil and SpawnPlayableModelMutation ~= "" then
				Rayfield:Notify({
					Title = "Playable Spawner",
					Content = 'Failed, mutation named "'.. SpawnPlayableModelMutation .. '" doesnt exist.',
					Duration = 6.5,
					Image = "x",
				})
				return
			end
			local Part =  Instance.new("Part", workspace)
			Part.Position = Players.LocalPlayer.Character.PrimaryPart.Position - Vector3.new(0, 2, 0)
			local Model = Instance.new("Model", workspace)
			Part.Parent = Model
			Model:SetAttribute("Index", SpawnPlayableModelName)
			Model:SetAttribute("Mutation", SpawnPlayableModelMutation)
			Model:AddTag("Animal")
			Part.Anchored = false
			Part.Transparency = 1
		end,
	})
end
