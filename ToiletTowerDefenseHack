LocalPlayer.PlayerGui.CustomMatchUI.Enabled = true

local function Color3ToHex(color)
 local r = math.floor(color.R * 255)
 local g = math.floor(color.G * 255)
 local b = math.floor(color.B * 255)
 return string.format("#%02X%02X%02X", r, g, b)
end

local function MakeTextUse(Color, Text)
 return '<font color="' .. Color3ToHex(Color) .. '">' .. Text .. '</font>'
end

local function Message(Color, Text)
 TextChatService.TextChannels.RBXGeneral:DisplaySystemMessage(MakeTextUse(Color, Text))
end

